{
  "name": "ict2216-practical-2400620",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Secure search application for ICT2216 practical lab test",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "node src/server.js",
    "lint": "eslint src public tests eslint.config.js",
    "test": "node --test tests/unit/*.test.js",
    "test:coverage": "c8 --reporter=lcov --reporter=text npm test",
    "test:integration": "node --test tests/integration/*.test.js",
    "test:ui": "node --test tests/ui/*.test.js",
    "security:eslint": "eslint src public tests --format @microsoft/eslint-formatter-sarif --output-file reports/eslint-security.sarif"
  },
  "dependencies": {
    "express": "5.2.1",
    "helmet": "8.3.0",
    "mysql2": "3.23.1"
  },
  "devDependencies": {
    "@microsoft/eslint-formatter-sarif": "3.1.0",
    "c8": "10.1.3",
    "eslint": "9.39.2",
    "eslint-plugin-security": "4.0.1",
    "selenium-webdriver": "4.46.0"
  }
}
